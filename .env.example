# Polymarket CLOB API
POLY_API_KEY=your-api-key
POLY_API_SECRET=your-api-secret
POLY_API_PASSPHRASE=your-api-passphrase
POLY_PRIVATE_KEY=your-wallet-private-key
POLY_FUNDER=your-funder-address

# Chain
CHAIN_ID=137
CLOB_HOST=https://clob.polymarket.com

# Copy-trade bot
COPY_TARGETS=0xproxywallet1,0xproxywallet2
COPY_SIZE_USD=10.0
COPY_MAX_PRICE=0.95
COPY_MIN_PRICE=0.05
COPY_POLL_INTERVAL=5
COPY_LOOKBACK_SECONDS=30
COPY_MAX_OPEN_POSITIONS=10
COPY_MAX_DAILY_SPEND=100.0
